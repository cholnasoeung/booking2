# Copy to .env.production on the VPS and fill in real values.
# Never commit the filled-in file — it stays only on the server.

# --- Database (MongoDB Atlas) ---
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# --- NextAuth ---
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_URL_INTERNAL=http://app:3000

# --- Public app URL (used to build links in emails, payment callbacks, etc.) ---
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Mobile auth (optional) ---
MOBILE_AUTH_SECRET=

# --- Email via Resend (optional) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=
ADMIN_ALERT_EMAIL=

# --- SMS via Twilio (optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Stripe payments (optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- ABA PayWay payments (optional) ---
ABA_API_KEY=
ABA_MERCHANT_ID=
